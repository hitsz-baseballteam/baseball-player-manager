# PostgreSQL connection string.
# Local development example: postgresql://localhost:5432/baseball_manager
# Production/server example: your Supabase Postgres connection string.
DATABASE_URL=
# Optional custom CA PEM for non-public roots (`\n` escaped or multi-line).
# Usually leave empty for local development.
DATABASE_CA_CERT=
# Optional pool `max` override. Leave unset to auto-pick based on the
# DATABASE_URL: 1 for Supabase transaction-mode Pooler (port 6543), 5 for
# everything else. Only bump this if you hit connection contention; a
# higher value can trigger "prepared statement already exists" on
# transaction-mode Pooler.
DB_POOL_MAX=
# Generate with: npm run auth:env -- "your-passcode"
APP_ADMIN_PASSCODE_HASH=
AUTH_SECRET=
